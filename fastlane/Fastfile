default_platform(:ios)

# Load .env file manually to ensure environment variables are set
require 'dotenv'
Dotenv.load('../.env')

platform :ios do

  # ---------------------------------------------------------------------------
  # Shared Logic
  # ---------------------------------------------------------------------------

  def build_and_distribute(scheme:, bundle_id:)
    # 1. Ensure git status is clean before building
    ensure_git_status_clean

    # 2. Increment build number for ALL targets
    # (Requires agvtool enabled in Xcode project settings)
    increment_build_number(xcodeproj: "TrackMyCafe.xcodeproj")

    # 3. Commit the version bump (so the repo is clean for next run if build fails)
    commit_version_bump(
      xcodeproj: "TrackMyCafe.xcodeproj",
      message: "chore: Bump build number [skip ci]", # [skip ci] prevents loop if you have CI
      force: true
    )

    # 4. Build the app
    build_app(
      workspace: "TrackMyCafe.xcworkspace",
      scheme: scheme,
      clean: true,
      export_method: "app-store",
      # Allow Xcode to update provisioning profiles if needed (Automatic Signing)
      xcargs: "-allowProvisioningUpdates"
    )

    # 4. Upload to TestFlight
    upload_to_testflight(
      app_identifier: bundle_id,
      skip_waiting_for_build_processing: false,
      changelog: "Updated build"               # Fallback changelog if none provided
    )
  end

  # ---------------------------------------------------------------------------
  # Public Lanes
  # ---------------------------------------------------------------------------

  desc "Deploy PROD to TestFlight (Scheme: TrackMyCafe Prod)"
  lane :prod do
    build_and_distribute(
      scheme: "TrackMyCafe Prod",
      bundle_id: "ICSOFT.TrackMyCafe"
    )
  end

  desc "Deploy BETA to TestFlight (Scheme: TrackMyCafe Beta)"
  lane :beta do
    build_and_distribute(
      scheme: "TrackMyCafe Beta",
      bundle_id: "ICSOFT.TrackMyCafe.beta"
    )
  end

  desc "Deploy DEV to TestFlight (Scheme: TrackMyCafe Dev)"
  lane :dev do
    # Note: Ensure "ICSOFT.TrackMyCafe.dev" exists in App Store Connect
    build_and_distribute(
      scheme: "TrackMyCafe Dev",
      bundle_id: "ICSOFT.TrackMyCafe.dev"
    )
  end

end
