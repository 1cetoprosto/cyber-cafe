rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow authenticated users to read and write to all documents
    // This is suitable for development/beta but should be restricted for production
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Alternatively, for more granular control (commented out):
    
    // Users collection: Allow users to read/write only their own data
    // match /users/{userId} {
    //   allow read, write: if request.auth != null && request.auth.uid == userId;
    //   
    //   // Subcollections under users (e.g. products, orders)
    //   match /{subcollection}/{document=**} {
    //      allow read, write: if request.auth != null && request.auth.uid == userId;
    //   }
    // }
    
    // Roles collection: Needed for initial sign up / role assignment
    // match /roles/{roleId} {
    //   allow read, write: if request.auth != null;
    // }
    
    // Other collections
    // match /admins/{adminId} { allow read, write: if request.auth != null; }
    // match /technicians/{techId} { allow read, write: if request.auth != null; }
  }
}
